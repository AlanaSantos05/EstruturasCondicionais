programa
{
	inclua biblioteca Matematica
-->mat
	
	funcao inicio()
	{

		// Declaração das variáveis
		real A, B, C, Delta, x1, x2

		// Entrada de dados
		escreva("Digite o valor de A: ")
		leia(A)

		// O valor de A não pode ser zero em uma equação do segundo grau
		se (A == 0) 
		{
			escreva("O valor de A não pode ser zero (não é uma equação do segundo grau).\n")
		}
		senao 
		{
			escreva("Digite o valor de B: ")
			leia(B)
			
			escreva("Digite o valor de C: ")
			leia(C)

			// Cálculo do Delta (b² - 4ac)
			Delta = (B * B) - (4 * A * C)
			escreva("\nO valor de Delta é: ", Delta, "\n")

			// Verificação das condições do Delta
			se (Delta < 0) 
			{
				escreva("A equação não possui raízes reais, pois o Delta é negativo.\n")
			}
			senao 
			{
				// Cálculo de x1 e x2 com os parênteses corretos na divisão
				x1 = (-B + mat.raiz(Delta, 2.0)) / (2 * A)
				x2 = (-B - mat.raiz(Delta, 2.0)) / (2 * A)

				escreva("O valor de x1 é: ", x1, "\n")
				escreva("O valor de x2 é: ", x2, "\n")
			}
		}
	}
	
	
}
